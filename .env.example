# Copy is created as `.env` on first import if `.env` is missing (see config.py).
# Fill TELEGRAM_* so every agent signal + aggregator alerts go to your chat.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 1 (default) = send every raw agent signal to Telegram. 0 = only urgent/high/critical (filtered).
TELEGRAM_FORWARD_ALL=1

# Set to 1 in production if you must not start without Telegram.
TRADINGBOT_REQUIRE_TELEGRAM=0

LOG_LEVEL=INFO
# Optional: WARNING to hide INFO in console (file logs still follow LOG_LEVEL).
# CONSOLE_LOG_LEVEL=INFO
